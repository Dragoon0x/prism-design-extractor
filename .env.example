# ============================================================================
# Prism — environment variables (example) — Vercel stack
# Copy to .env.local for local dev. Never commit real secrets.
# ============================================================================

# --- Core ---
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Postgres (Neon or Vercel Postgres) ---
DATABASE_URL=postgres://user:password@host.neon.tech/prism?sslmode=require

# --- Upstash Redis (SSE pub/sub + rate limiting) ---
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# --- Upstash QStash (durable job queue via HTTP callbacks) ---
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# --- Vercel Blob (screenshots, PDFs, generated artifact bundles) ---
# Provisioned automatically by `vercel env pull` when the Blob integration is connected.
BLOB_READ_WRITE_TOKEN=

# --- Encryption (wraps the Anthropic key envelope passed into worker routes) ---
# 32-byte base64 key. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AES_KEK=REPLACE_ME_WITH_32_BYTE_BASE64_KEY

# --- Anthropic (optional server-side fallback for the public demo landing page) ---
# BYOK is the default; users provide their own key via `X-Anthropic-Key`.
ANTHROPIC_API_KEY=

# --- Auth (optional; v1 works anonymous-only) ---
ENABLE_AUTH=false
AUTH_SECRET=
SMTP_URL=

# --- Rate limiting ---
RATE_LIMIT_ANON_PER_HOUR=20
RATE_LIMIT_SIGNED_PER_HOUR=200

# --- Model defaults (override per-request with user preference) ---
CLAUDE_VISION_MODEL=claude-sonnet-4-6
CLAUDE_REASONING_MODEL=claude-opus-4-7
CLAUDE_FAST_MODEL=claude-haiku-4-5-20251001

# --- Abuse controls ---
MAX_PDF_BYTES=52428800
MAX_IMAGE_BYTES=20971520
DOMAIN_BLOCKLIST=

# --- Extraction timeouts (Vercel Pro hard ceiling: 300s per function) ---
EXTRACTION_URL_TIMEOUT_MS=280000
EXTRACTION_PAGE_TIMEOUT_MS=28000
EXTRACTION_IMAGE_TIMEOUT_MS=45000

# --- Observability (optional) ---
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=prism

# --- Local dev override (optional) ---
# When set, @prism/browser uses the host Playwright install instead of Sparticuz Chromium.
# LOCAL_CHROMIUM=1
